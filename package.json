{
  "name": "audition-checker",
  "version": "1.0.0",
  "description": "Weekly cron job to monitor symphony orchestra audition pages for trumpet opportunities",
  "scripts": {
    "check": "ts-node src/check-auditions.ts",
    "check:dry": "DRY_RUN=true ts-node src/check-auditions.ts",
    "check:debug": "DRY_RUN=true CHECKER_DEBUG=true ts-node src/check-auditions.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "dotenv": "^17.3.1",
    "googleapis": "^144.0.0",
    "puppeteer": "^22.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "ts-node": "^10.9.0",
    "typescript": "^5.4.0",
    "vitest": "^4.0.18"
  }
}
